  "notes": "Windows persistence signature catalogue — DETECTION only, never used as payloads. Covers 8 canonical persistence categories that map to windows_quick_check.ps1 sections 07-12 and windows-host-check.md chapters 7-13. `location` uses canonical Windows paths / registry syntax; `detection_type` is the class of check the collector emits. Severity calibrated to hvv-window: any NEW entry in these locations is at least medium.",
  "patterns": [
    {"id": "SIG-WIN-001", "category": "run-key", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run", "detection_type": "registry_value_new", "severity": "medium", "description": "Standard HKLM Run key — new value on hvv-window is a persistence candidate", "false_positive": "legit software installers register here"},
    {"id": "SIG-WIN-002", "category": "run-key", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnce", "detection_type": "registry_value_new", "severity": "medium", "description": "HKLM RunOnce — one-shot boot exec", "false_positive": "installer post-reboot steps"},
    {"id": "SIG-WIN-003", "category": "run-key", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnceEx", "detection_type": "registry_value_new", "severity": "medium", "description": "HKLM RunOnceEx — rarely used by legit software; strong persistence signal", "false_positive": "very low"},
    {"id": "SIG-WIN-004", "category": "run-key", "location": "HKLM\\SOFTWARE\\Wow6432Node\\Microsoft\\Windows\\CurrentVersion\\Run", "detection_type": "registry_value_new", "severity": "medium", "description": "32-bit Run key on 64-bit hosts — often overlooked by defenders", "false_positive": "legacy 32-bit software"},
    {"id": "SIG-WIN-005", "category": "run-key", "location": "HKCU\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run", "detection_type": "registry_value_new", "severity": "medium", "description": "Per-user Run key — attacker-friendly (no admin required)", "false_positive": "browser / IM auto-start"},
    {"id": "SIG-WIN-006", "category": "run-key", "location": "HKCU\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnce", "detection_type": "registry_value_new", "severity": "medium", "description": "Per-user RunOnce", "false_positive": "low"},
    {"id": "SIG-WIN-007", "category": "run-key", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon\\Userinit", "detection_type": "registry_value_modified", "severity": "high", "description": "Winlogon Userinit — expected value is `C:\\Windows\\system32\\userinit.exe,` — any extra entry is high-severity", "false_positive": "very rare"},
    {"id": "SIG-WIN-008", "category": "run-key", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon\\Shell", "detection_type": "registry_value_modified", "severity": "high", "description": "Winlogon Shell — expected `explorer.exe`; replacement or append = P0-candidate persistence", "false_positive": "very rare"},
    {"id": "SIG-WIN-009", "category": "service", "location": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\<name>\\ImagePath", "detection_type": "service_new_or_pathmod", "severity": "high", "description": "Service ImagePath contains cmd.exe / powershell.exe / rundll32.exe / mshta.exe / regsvr32.exe", "false_positive": "rare (a few legit but named ones exist)"},
    {"id": "SIG-WIN-010", "category": "service", "location": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\<name>\\ImagePath", "detection_type": "service_new_unsigned", "severity": "medium", "description": "Service binary is unsigned or invalid signature", "false_positive": "in-house tools sometimes unsigned"},
    {"id": "SIG-WIN-011", "category": "service", "location": "sc.exe create <svc> binPath= …", "detection_type": "process_evidence_4688", "severity": "medium", "description": "sc.exe create observed in 4688 with binPath containing shell / non-Program-Files path", "false_positive": "install scripts"},
    {"id": "SIG-WIN-012", "category": "service", "location": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\<name>\\ImagePath", "detection_type": "service_registry_encoded", "severity": "high", "description": "ImagePath contains `-EncodedCommand`, `FromBase64String`, or long base64 blob", "false_positive": "very rare"},
    {"id": "SIG-WIN-013", "category": "scheduled-task", "location": "C:\\Windows\\System32\\Tasks\\", "detection_type": "task_xml_non_microsoft", "severity": "medium", "description": "Task XML Author != Microsoft/Windows and RunAs=SYSTEM or NT AUTHORITY\\SYSTEM", "false_positive": "third-party updaters (Google/Adobe/…)"},
    {"id": "SIG-WIN-014", "category": "scheduled-task", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Schedule\\TaskCache\\Tree\\", "detection_type": "task_registry", "severity": "medium", "description": "Task registered in TaskCache but no matching Task XML file → obfuscated persistence", "false_positive": "rare"},
    {"id": "SIG-WIN-015", "category": "scheduled-task", "location": "C:\\Windows\\System32\\Tasks\\<name>", "detection_type": "task_action_shell", "severity": "high", "description": "Task Action Exec containing cmd/powershell/rundll32/regsvr32/mshta", "false_positive": "some IT scripts"},
    {"id": "SIG-WIN-016", "category": "scheduled-task", "location": "any", "detection_type": "task_trigger_frequency", "severity": "medium", "description": "Task with Trigger repetition every ≤ 5 minutes (beacon persistence)", "false_positive": "some monitoring tasks"},
    {"id": "SIG-WIN-017", "category": "wmi-subscription", "location": "root\\subscription:__EventFilter", "detection_type": "wmi_filter_new", "severity": "high", "description": "New EventFilter — combined with __EventConsumer + Binding forms WMI persistence triad", "false_positive": "SCCM / OpsMgr components use WMI subs"},
    {"id": "SIG-WIN-018", "category": "wmi-subscription", "location": "root\\subscription:__EventConsumer", "detection_type": "wmi_consumer_commandline", "severity": "high", "description": "CommandLineEventConsumer with CommandLineTemplate = shell / powershell / mshta / rundll32", "false_positive": "very rare"},
    {"id": "SIG-WIN-019", "category": "wmi-subscription", "location": "root\\subscription:__FilterToConsumerBinding", "detection_type": "wmi_binding_new", "severity": "high", "description": "Binding between filter and consumer — the closing link that activates the triad", "false_positive": "rare"},
    {"id": "SIG-WIN-020", "category": "wmi-subscription", "location": "root\\default:__EventFilter", "detection_type": "wmi_alt_namespace", "severity": "high", "description": "EventFilter in root\\default (non-standard namespace) — deliberate evasion of `root\\subscription` scans", "false_positive": "very rare"},
    {"id": "SIG-WIN-021", "category": "com-hijack", "location": "HKCU\\Software\\Classes\\CLSID\\<clsid>\\InprocServer32", "detection_type": "com_hkcu_override", "severity": "high", "description": "Per-user CLSID override — HKCU takes precedence over HKCR for the user; classic COM hijack", "false_positive": "some legit Chrome/Office installs put entries under HKCU\\Classes"},
    {"id": "SIG-WIN-022", "category": "com-hijack", "location": "HKCU\\Software\\Classes\\CLSID\\<clsid>\\TreatAs", "detection_type": "com_treatas", "severity": "high", "description": "TreatAs redirect of a well-known CLSID (e.g. `{ab8902b4-09ca-4bb6-b78d-a8f59079a8d5}` = Thumbnail Cache) → hijack", "false_positive": "very rare"},
    {"id": "SIG-WIN-023", "category": "com-hijack", "location": "HKCR\\CLSID\\<clsid>\\InprocServer32", "detection_type": "com_dll_path_unsigned", "severity": "high", "description": "CLSID InprocServer32 pointing to unsigned DLL in Users\\* / ProgramData\\* / Temp\\*", "false_positive": "some 3rd party legit"},
    {"id": "SIG-WIN-024", "category": "ifeo-debugger", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Image File Execution Options\\<exe>\\Debugger", "detection_type": "ifeo_debugger_set", "severity": "high", "description": "IFEO Debugger value set on target exe (e.g. sethc.exe / utilman.exe / notepad.exe) — replaces process at launch", "false_positive": "very rare, mostly attacker persistence"},
    {"id": "SIG-WIN-025", "category": "ifeo-debugger", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Image File Execution Options\\<exe>\\GlobalFlag=0x200", "detection_type": "ifeo_silent_process_exit", "severity": "high", "description": "IFEO Silent Process Exit hook — attacker can trigger arbitrary process on target exe exit", "false_positive": "very rare"},
    {"id": "SIG-WIN-026", "category": "appinit-dlls", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Windows\\AppInit_DLLs", "detection_type": "appinit_dll_set", "severity": "high", "description": "AppInit_DLLs non-empty AND LoadAppInit_DLLs=1 — every user32.dll load injects the DLL", "false_positive": "very rare on modern Windows (deprecated since Win8 default off)"},
    {"id": "SIG-WIN-027", "category": "appinit-dlls", "location": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\AppCertDlls", "detection_type": "appcert_dll_set", "severity": "high", "description": "AppCertDlls — DLL loaded into every process that calls CreateProcess", "false_positive": "very rare"},
    {"id": "SIG-WIN-028", "category": "dll-search-order", "location": "C:\\Windows\\System32\\<dll> shadowed by C:\\<workdir>\\<dll>", "detection_type": "dll_side_by_side", "severity": "high", "description": "Known-DLL shadowing by a same-named file in an application working dir (side-loading)", "false_positive": "some poorly-written apps"},
    {"id": "SIG-WIN-029", "category": "dll-search-order", "location": "any process cwd", "detection_type": "phantom_dll", "severity": "medium", "description": "Process loads a DLL from cwd that is not signed & not in Known DLLs — phantom-DLL loading", "false_positive": "medium"},
    {"id": "SIG-WIN-030", "category": "startup-folder", "location": "C:\\ProgramData\\Microsoft\\Windows\\Start Menu\\Programs\\StartUp\\", "detection_type": "file_new", "severity": "medium", "description": "New .lnk / .exe / .vbs / .bat / .ps1 in all-users Startup folder", "false_positive": "legit software installer"},
    {"id": "SIG-WIN-031", "category": "startup-folder", "location": "C:\\Users\\<u>\\AppData\\Roaming\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\", "detection_type": "file_new", "severity": "medium", "description": "New file in per-user Startup folder (attacker-friendly: no admin required)", "false_positive": "medium"},
    {"id": "SIG-WIN-032", "category": "startup-folder", "location": "startup lnk target", "detection_type": "lnk_target_shell", "severity": "high", "description": "Startup .lnk whose Target = powershell / cmd / rundll32 / mshta with parameters", "false_positive": "very rare"},
    {"id": "SIG-WIN-033", "category": "run-key", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Shell Folders", "detection_type": "registry_folder_redirect", "severity": "high", "description": "Startup folder path redirected via registry to attacker-controlled path", "false_positive": "very rare"},
    {"id": "SIG-WIN-034", "category": "run-key", "location": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\BootExecute", "detection_type": "registry_bootexecute", "severity": "high", "description": "BootExecute other than autocheck autochk * — runs pre-boot", "false_positive": "very rare"},
    {"id": "SIG-WIN-035", "category": "service", "location": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\<name>\\Parameters\\ServiceDll", "detection_type": "service_dll_svchost", "severity": "high", "description": "svchost-hosted service with ServiceDll pointing outside System32", "false_positive": "very rare"},
    {"id": "SIG-WIN-036", "category": "run-key", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\ShellIconOverlayIdentifiers\\<name>", "detection_type": "shell_extension", "severity": "medium", "description": "Shell extension COM registered — loaded into every explorer.exe", "false_positive": "cloud storage clients (OneDrive/Dropbox)"},
    {"id": "SIG-WIN-037", "category": "scheduled-task", "location": "any", "detection_type": "task_hidden", "severity": "high", "description": "Task has Hidden=true attribute → deliberate evasion of `schtasks /query`", "false_positive": "some Microsoft tasks are legitimately hidden"},
    {"id": "SIG-WIN-038", "category": "wmi-subscription", "location": "any consumer", "detection_type": "wmi_consumer_activescript", "severity": "high", "description": "ActiveScriptEventConsumer with inline JScript/VBScript body — classic WMI persistence (SEASHARPEE, POWERTON)", "false_positive": "very rare"},
    {"id": "SIG-WIN-039", "category": "com-hijack", "location": "HKCU\\Software\\Classes\\Folder\\shell\\open\\command", "detection_type": "com_shell_verb", "severity": "high", "description": "Folder / drive open verb hijacked — triggers on user browsing", "false_positive": "very rare"},
    {"id": "SIG-WIN-040", "category": "run-key", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon\\Notify", "detection_type": "winlogon_notify", "severity": "high", "description": "Winlogon Notify package — legacy but still supported on some servers", "false_positive": "very rare"},
    {"id": "SIG-WIN-041", "category": "service", "location": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\<name>\\FailureCommand", "detection_type": "service_failure_action", "severity": "high", "description": "FailureCommand invokes shell / non-standard binary — attacker triggers by killing the service", "false_positive": "very rare"},
    {"id": "SIG-WIN-042", "category": "ifeo-debugger", "location": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\AeDebug\\Debugger", "detection_type": "aedebug_hijack", "severity": "high", "description": "Default post-mortem debugger replaced — auto-runs on any process crash", "false_positive": "very rare"},
    {"id": "SIG-WIN-043", "category": "dll-search-order", "location": "C:\\Windows\\System32\\wbem\\<dll>", "detection_type": "wmi_dll_hijack", "severity": "high", "description": "Non-signed / non-Microsoft DLL under wbem\\ directory (loaded by WMI infrastructure)", "false_positive": "very rare"},
    {"id": "SIG-WIN-044", "category": "appinit-dlls", "location": "HKLM\\SOFTWARE\\Microsoft\\Cryptography\\OID\\EncodingType 0\\CryptSIPDllVerifyIndirectData\\<CLSID>\\Dll", "detection_type": "sip_hijack", "severity": "high", "description": "Subject Interface Package hijack — bypasses signature checks on signed exe", "false_positive": "very rare"},
    {"id": "SIG-WIN-045", "category": "run-key", "location": "HKLM\\SOFTWARE\\Microsoft\\Netsh", "detection_type": "netsh_helper", "severity": "high", "description": "Netsh helper DLL — loaded on `netsh` invocation (which is common in scripts)", "false_positive": "very rare"},
    {"id": "SIG-WIN-046", "category": "com-hijack", "location": "HKCR\\.<ext>\\<progid>\\shell\\open\\command", "detection_type": "file_association_hijack", "severity": "high", "description": "File association handler for common ext (txt/docx/pdf) hijacked — triggers on double-click", "false_positive": "very rare"},
    {"id": "SIG-WIN-047", "category": "startup-folder", "location": "C:\\Users\\<u>\\AppData\\Local\\Microsoft\\OneDrive\\StandaloneUpdater.exe", "detection_type": "trusted_binary_replaced", "severity": "high", "description": "Well-known Autorun binary path replaced with unsigned file — classic 'live off the land' persistence", "false_positive": "very rare"},
    {"id": "SIG-WIN-048", "category": "service", "location": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\<name>\\ImagePath referencing \\\\<remote>\\...", "detection_type": "service_unc_path", "severity": "high", "description": "Service ImagePath pointing to UNC path — service binary lives on remote share (evasion + remote control)", "false_positive": "some cluster / SCCM deployments"}
