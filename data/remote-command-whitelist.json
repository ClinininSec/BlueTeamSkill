{
  "version": "0.4-M0",
  "updated_at": "2026-07-01",
  "total": 59,
  "notes": "3-tier whitelist for hvv-defender remote mode. Tier 1 = read-only audit; Tier 2 = collect/upload; Tier 3 = mutating disposal (default disabled, requires --allow-mutating + written customer authorization + second oral confirmation). Placeholder variables validated by ssh_probe.py before command expansion. No rm/mv/chmod/chown/useradd/userdel/reboot/shutdown/nc/curl/wget/ssh/scp/sftp/dd/mkfs/bash -c wildcards.",
  "placeholder_patterns": {
    "<pid>": "^[0-9]{1,7}$",
    "<user>": "^[a-zA-Z_][a-zA-Z0-9_-]{0,31}$",
    "<ip>": "^([0-9]{1,3}\\.){3}[0-9]{1,3}$|^[0-9a-fA-F:]{2,39}$",
    "<port>": "^[0-9]{1,5}$",
    "<service>": "^[a-zA-Z0-9_@.:-]{1,64}$",
    "<file>": "^[a-zA-Z0-9_./-]{1,255}$",
    "<key_comment>": "^[a-zA-Z0-9_@.-]{1,64}$",
    "<line_marker>": "^# HVV-DEFENDER-MANAGED-[A-Z0-9-]{1,32}$"
  },
