{
  "version": "0.3",
  "updated_at": "2026-07-01",
  "total": 38,
  "notes": "Sysmon high-value detection rules — DETECTION only. evtx_hunt.py may load these via --sysmon-data to enrich its Sysmon channel matcher; blue teams may also feed the same list into their own SIEM (Splunk/ELK/Sentinel) since the pattern column is a language-neutral regex. Field names follow the Sysmon 15.x schema.",
  "rules": [
    {"id": "SIG-SYSMON-001", "event_id": 1, "field": "CommandLine", "pattern": "(?i)(powershell|pwsh)\\.exe\\s+[-/]e(nc(odedcommand)?)?\\b", "severity": "high", "description": "PowerShell -EncodedCommand execution", "false_positive": "legitimate ops rarely use -enc"},
    {"id": "SIG-SYSMON-002", "event_id": 1, "field": "CommandLine", "pattern": "(?i)FromBase64String\\s*\\(", "severity": "high", "description": ".NET FromBase64String in cmdline — encoded payload marker", "false_positive": "low"},
    {"id": "SIG-SYSMON-003", "event_id": 1, "field": "CommandLine", "pattern": "(?i)(iex|invoke-expression)\\b", "severity": "medium", "description": "PowerShell IEX / Invoke-Expression", "false_positive": "some legit modules"},
    {"id": "SIG-SYSMON-004", "event_id": 1, "field": "CommandLine", "pattern": "(?i)-nop\\b|-noprofile\\b", "severity": "low", "description": "-NoProfile flag — often paired with covert exec", "false_positive": "high on its own"},
    {"id": "SIG-SYSMON-005", "event_id": 1, "field": "CommandLine", "pattern": "(?i)-windowstyle\\s+hidden|-w\\s+hidden", "severity": "medium", "description": "Hidden window style — evasion tell", "false_positive": "some scripts"},
    {"id": "SIG-SYSMON-006", "event_id": 1, "field": "CommandLine", "pattern": "(?i)certutil(\\.exe)?\\s+.*-(urlcache|encode|decode|decodehex)\\b", "severity": "high", "description": "certutil LOLBIN abuse (download / encode / decode)", "false_positive": "very rare"},
    {"id": "SIG-SYSMON-007", "event_id": 1, "field": "CommandLine", "pattern": "(?i)bitsadmin(\\.exe)?\\s+.*/transfer\\b", "severity": "high", "description": "bitsadmin /transfer — file download LOLBIN", "false_positive": "some IT scripts"},
    {"id": "SIG-SYSMON-008", "event_id": 1, "field": "CommandLine", "pattern": "(?i)mshta(\\.exe)?\\s+.*https?://", "severity": "high", "description": "mshta.exe with remote URL — HTA delivery", "false_positive": "very rare"},
    {"id": "SIG-SYSMON-009", "event_id": 1, "field": "CommandLine", "pattern": "(?i)regsvr32(\\.exe)?\\s+.*(/s\\s+)?/i:https?://", "severity": "high", "description": "regsvr32 /i:URL — Squibbly Two-step / Squiblydoo LOLBIN", "false_positive": "very rare"},
    {"id": "SIG-SYSMON-010", "event_id": 1, "field": "CommandLine", "pattern": "(?i)rundll32(\\.exe)?\\s+.*(shell32|javascript:|url\\.dll,\\s*FileProtocolHandler)", "severity": "high", "description": "rundll32 with shell32/javascript/URL — LOLBIN patterns", "false_positive": "very rare"},
    {"id": "SIG-SYSMON-011", "event_id": 1, "field": "CommandLine", "pattern": "(?i)\\bnet(\\.exe)?\\s+(user|group|localgroup)\\b", "severity": "low", "description": "net user/group/localgroup enumeration", "false_positive": "high (legit ops)"},
    {"id": "SIG-SYSMON-012", "event_id": 1, "field": "CommandLine", "pattern": "(?i)whoami(\\.exe)?\\s+(/all|/groups|/priv)", "severity": "low", "description": "whoami reconnaissance", "false_positive": "high"},
    {"id": "SIG-SYSMON-013", "event_id": 1, "field": "CommandLine", "pattern": "(?i)quser|qwinsta", "severity": "low", "description": "Session enumeration commands", "false_positive": "high"},
    {"id": "SIG-SYSMON-014", "event_id": 1, "field": "CommandLine", "pattern": "(?i)nltest\\s+/(dclist|domain_trusts|dsgetdc)", "severity": "medium", "description": "AD domain enumeration via nltest", "false_positive": "some admin scripts"},
    {"id": "SIG-SYSMON-015", "event_id": 1, "field": "CommandLine", "pattern": "(?i)vssadmin\\s+delete\\s+shadows", "severity": "high", "description": "vssadmin delete shadows — ransomware preparation", "false_positive": "very rare"},
    {"id": "SIG-SYSMON-016", "event_id": 1, "field": "CommandLine", "pattern": "(?i)wmic\\s+shadowcopy\\s+delete", "severity": "high", "description": "wmic shadowcopy delete — ransomware preparation", "false_positive": "very rare"},
    {"id": "SIG-SYSMON-017", "event_id": 1, "field": "CommandLine", "pattern": "(?i)wevtutil\\s+cl\\s+", "severity": "high", "description": "wevtutil cl — clear event log (anti-forensic)", "false_positive": "rare"},
    {"id": "SIG-SYSMON-018", "event_id": 1, "field": "ParentImage", "pattern": "(?i)\\\\(WINWORD|EXCEL|POWERPNT|OUTLOOK|MSPUB|ONENOTE|MSACCESS)\\.EXE$", "severity": "high", "description": "Office parent process — child should not be shell", "false_positive": "some Office add-ins launch cmd"},
    {"id": "SIG-SYSMON-019", "event_id": 1, "field": "ParentImage", "pattern": "(?i)\\\\(w3wp|httpd|nginx|tomcat|java)\\.exe$", "severity": "high", "description": "Web server parent — child launching cmd/ps = webshell RCE", "false_positive": "some deploy hooks"},
    {"id": "SIG-SYSMON-020", "event_id": 3, "field": "DestinationPort", "pattern": "^(4444|1337|8888|31337|7777|5555|9999|6666)$", "severity": "medium", "description": "Well-known offensive-tool listener ports", "false_positive": "medium"},
    {"id": "SIG-SYSMON-021", "event_id": 3, "field": "DestinationHostname", "pattern": "(?i)\\.(top|xyz|tk|ml|ga|cf|gq)$", "severity": "medium", "description": "Free / abused TLDs commonly used by C2", "false_positive": "some legit but rare"},
    {"id": "SIG-SYSMON-022", "event_id": 7, "field": "ImageLoaded", "pattern": "(?i)C:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Local\\\\Temp\\\\.*\\.dll$", "severity": "medium", "description": "DLL loaded from user Temp dir", "false_positive": "medium (some installers)"},
    {"id": "SIG-SYSMON-023", "event_id": 7, "field": "Signed", "pattern": "^false$", "severity": "low", "description": "Unsigned DLL loaded — cross with path for real triage", "false_positive": "high on its own"},
    {"id": "SIG-SYSMON-024", "event_id": 8, "field": "SourceImage", "pattern": "(?i)\\\\(powershell|pwsh|rundll32|regsvr32|mshta)\\.exe$", "severity": "high", "description": "CreateRemoteThread from script/lolbin process", "false_positive": "very rare"},
    {"id": "SIG-SYSMON-025", "event_id": 10, "field": "TargetImage", "pattern": "(?i)\\\\lsass\\.exe$", "severity": "high", "description": "LSASS access — potential credential dump", "false_positive": "some AV / EDR products"},
    {"id": "SIG-SYSMON-026", "event_id": 10, "field": "GrantedAccess", "pattern": "^0x1010|^0x1410|^0x143a", "severity": "high", "description": "Suspicious GrantedAccess masks on LSASS (dump-compatible)", "false_positive": "some system processes"},
    {"id": "SIG-SYSMON-027", "event_id": 11, "field": "TargetFilename", "pattern": "(?i)\\\\Startup\\\\.*\\.(lnk|exe|vbs|bat|ps1)$", "severity": "high", "description": "File created in Startup folder", "false_positive": "installer post-install"},
    {"id": "SIG-SYSMON-028", "event_id": 11, "field": "TargetFilename", "pattern": "(?i)\\\\AppData\\\\Local\\\\Temp\\\\.*\\.(exe|dll|ps1)$", "severity": "medium", "description": "Executable dropped in user Temp", "false_positive": "medium"},
    {"id": "SIG-SYSMON-029", "event_id": 11, "field": "TargetFilename", "pattern": "(?i)\\\\Windows\\\\(System32|SysWOW64)\\\\.*\\.(exe|dll)$", "severity": "high", "description": "New file written into System32/SysWOW64 by non-Microsoft process", "false_positive": "MS installer"},
    {"id": "SIG-SYSMON-030", "event_id": 12, "field": "TargetObject", "pattern": "(?i)\\\\Software\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Run(Once|OnceEx|Services|ServicesOnce)?$", "severity": "medium", "description": "Registry event on Run keys — cross with ProcessName", "false_positive": "installers"},
    {"id": "SIG-SYSMON-031", "event_id": 13, "field": "TargetObject", "pattern": "(?i)Image File Execution Options\\\\.*\\\\Debugger$", "severity": "high", "description": "IFEO Debugger value set", "false_positive": "very rare"},
    {"id": "SIG-SYSMON-032", "event_id": 13, "field": "TargetObject", "pattern": "(?i)Winlogon\\\\(Shell|Userinit|Notify)$", "severity": "high", "description": "Winlogon Shell/Userinit/Notify modified", "false_positive": "very rare"},
    {"id": "SIG-SYSMON-033", "event_id": 15, "field": "TargetFilename", "pattern": "(?i)\\.exe:.*", "severity": "high", "description": "Alternate Data Stream on exe — Zone.Identifier is normal; other names are suspicious", "false_positive": "Zone.Identifier is legit; filter it"},
    {"id": "SIG-SYSMON-034", "event_id": 17, "field": "PipeName", "pattern": "(?i)\\\\(mimikatz|paexec|cobaltstrike|msagent|status_\\d+)", "severity": "high", "description": "Named pipe matching known offensive tool signatures", "false_positive": "very rare"},
    {"id": "SIG-SYSMON-035", "event_id": 19, "field": "Operation", "pattern": "(?i)^Created$", "severity": "high", "description": "WMI EventFilter created", "false_positive": "SCCM / OpsMgr"},
    {"id": "SIG-SYSMON-036", "event_id": 20, "field": "Operation", "pattern": "(?i)^Created$", "severity": "high", "description": "WMI EventConsumer created", "false_positive": "SCCM / OpsMgr"},
    {"id": "SIG-SYSMON-037", "event_id": 21, "field": "Operation", "pattern": "(?i)^Created$", "severity": "high", "description": "WMI Filter->Consumer binding created — the closing link of the triad", "false_positive": "rare"},
    {"id": "SIG-SYSMON-038", "event_id": 22, "field": "QueryName", "pattern": "(?i)(\\.duckdns\\.org|\\.no-ip\\.com|paste\\.ee|transfer\\.sh|ngrok\\.io)$", "severity": "medium", "description": "DNS query to well-known dynamic-DNS / paste / tunnelling providers", "false_positive": "medium"}
  ]
}
