  "notes": "Detection-only patterns for pcap flow + string sniff. Never reproduces payloads. Calibrate severity per site. v0.3-M1 adds SIG-TRAF-087~126 covering TLS JA3/JA3S fingerprints, DNS covert channel deep heuristics, and CN red-team tooling.",
  "signatures": [
    {"id": "SIG-TRAF-001", "category": "c2", "view": "http", "field": "uri", "pattern": "(?i)/(aaa9|cm|dpixel|__utm\\.gif|pixel\\.gif|cx)", "tool": "cobalt-strike", "severity": "high", "description": "CobaltStrike default Malleable profile URIs", "false_positive": "legitimate analytics endpoints may collide"},
    {"id": "SIG-TRAF-002", "category": "c2", "view": "http", "field": "uri", "pattern": "(?i)/submit\\.php\\?id=\\d+", "tool": "cobalt-strike", "severity": "high", "description": "CobaltStrike default post-exploitation staging URI", "false_positive": "generic form endpoint pattern"},
    {"id": "SIG-TRAF-003", "category": "c2", "view": "http", "field": "ua", "pattern": "(?i)Mozilla/5\\.0 \\(compatible; MSIE 9\\.0; Windows NT 6\\.1; WOW64; Trident/5\\.0", "tool": "cobalt-strike", "severity": "medium", "description": "CobaltStrike stock UA in default profile", "false_positive": "legacy IE clients"},
    {"id": "SIG-TRAF-004", "category": "c2", "view": "http", "field": "request_line_excerpt", "pattern": "(?i)__cfduid=|Cookie:\\s*__cfduid=", "tool": "cobalt-strike", "severity": "medium", "description": "CobaltStrike fake cloudflare cookie", "false_positive": "very old Cloudflare deployments"},
    {"id": "SIG-TRAF-005", "category": "c2", "view": "flow", "field": "payload_first_bytes", "pattern": "\\\\\\\\PIPE\\\\\\\\status_", "tool": "cobalt-strike", "severity": "high", "description": "CobaltStrike SMB beacon named pipe pattern", "false_positive": "extremely rare in benign traffic"},
    {"id": "SIG-TRAF-006", "category": "c2", "view": "flow", "field": "payload_first_bytes", "pattern": "\\\\\\\\PIPE\\\\\\\\msagent_", "tool": "cobalt-strike", "severity": "high", "description": "CobaltStrike msagent named pipe", "false_positive": "none known"},
    {"id": "SIG-TRAF-007", "category": "c2", "view": "tls", "field": "cert_cn", "pattern": "(?i)^(Major, |CN=Major)$", "tool": "cobalt-strike", "severity": "medium", "description": "CobaltStrike default self-signed CN", "false_positive": "misconfig on legit test env"},
    {"id": "SIG-TRAF-008", "category": "c2", "view": "dns", "field": "qname", "pattern": "^[a-f0-9]{20,}\\.[a-z0-9-]{4,20}\\.[a-z]{2,10}$", "tool": "sliver", "severity": "high", "description": "Sliver DNS C2 hex-encoded qname", "false_positive": "some CDN hash-based subdomains"},
