    {"id": "SIG-TRAF-011", "category": "c2", "view": "http", "field": "uri", "pattern": "(?i)/(login|admin)/process\\.php", "tool": "empire", "severity": "medium", "description": "Empire default stager path", "false_positive": "old PHP apps"},
    {"id": "SIG-TRAF-012", "category": "c2", "view": "http", "field": "uri", "pattern": "(?i)/news\\.php\\?[a-z]+=", "tool": "empire", "severity": "medium", "description": "Empire post-exploitation URI", "false_positive": "CMS with news module"},
